{
  "expo": {
    "name": "Recipe Box",
    "slug": "recipe-box",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "recipebox",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "5",
      "bundleIdentifier": "com.dardern.recipebox",
      "infoPlist": {
        "NSCameraUsageDescription": "Recipe Box uses your camera to capture recipe pages for OCR.",
        "NSPhotoLibraryUsageDescription": "Recipe Box accesses your photo library so you can import recipe photos.",
        "NSRemindersUsageDescription": "Recipe Box can add ingredients to your Supermarket List in Reminders.",
        "LSSupportsOpeningDocumentsInPlace": false,
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Recipe Box Recipe",
            "CFBundleTypeRole": "Owner",
            "LSHandlerRank": "Owner",
            "LSItemContentTypes": ["com.dardern.recipebox.recipe"]
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.dardern.recipebox.recipe",
            "UTTypeDescription": "Recipe Box Recipe",
            "UTTypeConformsTo": ["public.json"],
            "UTTypeTagSpecification": {
              "public.filename-extension": ["recipebox"],
              "public.mime-type": "application/json"
            }
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "com.yourname.recipebox",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Recipe Box accesses your photo library to import recipe images.",
          "cameraPermission": "Recipe Box uses your camera to capture recipe pages."
        }
      ],
      "expo-sqlite",
      "./plugins/withXcode26Fix",
      "./plugins/withDocumentConfig"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3102db1e-1564-4abd-b65b-77bc27db400f"
      }
    }
  }
}
